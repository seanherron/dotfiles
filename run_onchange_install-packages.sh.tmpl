#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
install_darwin_npm_globals() {
  if ! command -v npm &>/dev/null; then
    echo "npm is required to install npm global packages" >&2
    exit 1
  fi

  npm_packages=(
{{ range .packages.darwinNpmGlobals }}    {{ . | quote }}
{{ end }}  )

  ((${#npm_packages[@]})) || return 0
  npm install -g "${npm_packages[@]}" --no-fund
}

uninstall_legacy_codex_cask() {
  if brew list --cask codex &>/dev/null; then
    brew uninstall --cask codex
  fi
}

# --- macOS: Homebrew + casks + Mac App Store -------------------------------
{{ if eq .profile "personal" -}}
# On personal machines the GUI apps (personalCasks) install into /Applications
# and may invoke sudo; authenticate once up front and refresh the credential
# cache until this script exits. Work machines get those apps from IT/MDM (gated
# out of the bundle below) so brew needs no sudo there — skip this to avoid an
# extra password prompt. Sudo tickets are NOT shared across chezmoi's separate
# script processes, so each script that needs sudo must prime its own.
if ! sudo -n true 2>/dev/null; then
  sudo -v
fi
script_pid=$$
(
  while kill -0 "$script_pid" 2>/dev/null; do
    sleep 60
    sudo -n true 2>/dev/null || exit
  done
) &
sudo_keepalive_pid=$!
trap 'kill "$sudo_keepalive_pid" 2>/dev/null || true' EXIT
{{ end -}}

uninstall_legacy_codex_cask

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwinBrews -}}
brew {{ . | quote }}
{{ end -}}
{{ if eq .profile "work" -}}
{{ range .packages.workBrews -}}
brew {{ . | quote }}
{{ end -}}
{{ end -}}
{{ range .packages.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ if eq .profile "personal" -}}
{{ range .packages.personalCasks -}}
cask {{ . | quote }}
{{ end -}}
{{ end -}}
{{ range .packages.mas -}}
{{- $parts := splitn ":" 2 . -}}
mas {{ index $parts "_1" | quote }}, id: {{ index $parts "_0" }}
{{ end -}}
EOF

install_darwin_npm_globals
{{- else -}}
# --- Linux: Homebrew on Linux, cross-platform CLI brews only ---------------
# Bootstrap Homebrew if it isn't on PATH yet (no sudo needed for brew itself
# once the prefix is writable; the official installer handles first-time setup).
if ! command -v brew &>/dev/null; then
  for _brew in /home/linuxbrew/.linuxbrew/bin/brew "$HOME/.linuxbrew/bin/brew"; do
    [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
  done
fi
if ! command -v brew &>/dev/null; then
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  for _brew in /home/linuxbrew/.linuxbrew/bin/brew "$HOME/.linuxbrew/bin/brew"; do
    [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
  done
fi

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{- end }}
