#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
# --- macOS: Homebrew + casks + Mac App Store -------------------------------
# brew bundle installs casks one-by-one; each may invoke sudo. Authenticate once
# and refresh the credential cache until this script exits.
if ! sudo -n true 2>/dev/null; then
  sudo -v
fi
script_pid=$$
(
  while kill -0 "$script_pid" 2>/dev/null; do
    sleep 60
    sudo -n true 2>/dev/null || exit
  done
) &
sudo_keepalive_pid=$!
trap 'kill "$sudo_keepalive_pid" 2>/dev/null || true' EXIT

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwinBrews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.casks -}}
cask {{ . | quote }}
{{ end -}}
{{ range .packages.mas -}}
{{- $parts := splitn ":" 2 . -}}
mas {{ index $parts "_1" | quote }}, id: {{ index $parts "_0" }}
{{ end -}}
EOF
{{- else -}}
# --- Linux: Homebrew on Linux, cross-platform CLI brews only ---------------
# Bootstrap Homebrew if it isn't on PATH yet (no sudo needed for brew itself
# once the prefix is writable; the official installer handles first-time setup).
if ! command -v brew &>/dev/null; then
  for _brew in /home/linuxbrew/.linuxbrew/bin/brew "$HOME/.linuxbrew/bin/brew"; do
    [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
  done
fi
if ! command -v brew &>/dev/null; then
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  for _brew in /home/linuxbrew/.linuxbrew/bin/brew "$HOME/.linuxbrew/bin/brew"; do
    [[ -x "$_brew" ]] && eval "$("$_brew" shellenv)" && break
  done
fi

brew bundle --file=/dev/stdin <<EOF
{{ range .packages.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF
{{- end }}
