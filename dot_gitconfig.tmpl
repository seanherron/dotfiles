[user]
    name = {{ .name }}
    email = {{ .email }}
    signingkey = {{ .signingKey | quote }}

[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
{{- if and (eq .chezmoi.os "darwin") (stat "/Applications/1Password.app") }}
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- end }}
    allowedSignersFile = ~/.config/git/allowed_signers

[init]
    defaultBranch = main

[pull]
    rebase = true

[fetch]
    prune = true

[push]
    autoSetupRemote = true
    default = simple

[rerere]
    enabled = true

[rebase]
    autoStash = true
    autoSquash = true

[diff]
    algorithm = histogram
    colorMoved = default

[merge]
    conflictstyle = zdiff3

# git-delta — syntax-highlighted diffs in `git diff`, `git log -p`, `git show`.
# Falls back gracefully to the default pager if delta isn't installed yet.
[core]
    pager = delta
    excludesfile = ~/.gitignore_global

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true            # n / N to jump between diff sections
    line-numbers = true
    syntax-theme = Catppuccin Mocha
    side-by-side = false       # one-off override: `git -c delta.side-by-side=true diff`

[column]
    ui = auto

[branch]
    sort = -committerdate

# Optional per-directory identity overrides. Uncomment and create the include
# files (e.g. ~/.gitconfig-work) to use different name/email/signingkey inside
# specific directories on the same machine.
# [includeIf "gitdir:~/work/"]
#     path = ~/.gitconfig-work
# [includeIf "gitdir:~/personal/"]
#     path = ~/.gitconfig-personal
