#!/bin/bash
# Enable the Thales security key (pam-u2f) as an OPTIONAL auth method for sudo.
#
# macOS Sonoma+ (incl. Tahoe/26) ships /etc/pam.d/sudo with `auth include
# sudo_local`, and sudo_local survives OS updates — so that is the sanctioned
# place to hook in pam_u2f rather than editing /etc/pam.d/sudo directly.
#
# `sufficient` => touch the registered key to authenticate; if the key is
# absent or you decline, sudo falls back to your password. There is no lockout
# risk: the default password stack (pam_opendirectory) still runs.
#
# Gated to work + darwin via .chezmoiignore. Register a key first with:
#   pamu2fcfg -u "$USER" > ~/.config/Yubico/u2f_keys
set -euo pipefail

authfile="{{ .chezmoi.homeDir }}/.config/Yubico/u2f_keys"

# Version-stable module path (opt/ survives pam-u2f version bumps). Skip quietly
# if pam-u2f isn't installed yet rather than breaking the whole apply.
if ! module="$(brew --prefix pam-u2f 2>/dev/null)/lib/pam/pam_u2f.so" || [[ ! -f "$module" ]]; then
  echo "setup-pam-u2f-sudo: pam_u2f.so not found (is pam-u2f installed?); skipping."
  exit 0
fi

desired="$(cat <<EOF
# sudo_local — managed by chezmoi (run_onchange_setup-pam-u2f-sudo.sh.tmpl).
# Optional security-key auth for sudo: touch the registered key, or fall back
# to your password. Included ahead of the default stack via \`auth include sudo_local\`.
auth       sufficient     $module authfile=$authfile cue
EOF
)"

# Idempotent: only touch the root-owned file (with sudo) when content differs.
if [[ -f /etc/pam.d/sudo_local ]] && diff -q <(printf '%s\n' "$desired") /etc/pam.d/sudo_local >/dev/null 2>&1; then
  echo "setup-pam-u2f-sudo: /etc/pam.d/sudo_local already current."
  exit 0
fi

# Warn (don't fail) if the key hasn't been registered yet — sudo_local is still
# safe to install because pam_u2f just fails through to the password prompt.
if [[ ! -s "$authfile" ]]; then
  echo "setup-pam-u2f-sudo: NOTE: $authfile is missing/empty."
  echo "  Register your key: pamu2fcfg -u \"\$USER\" > \"$authfile\" && chmod 600 \"$authfile\""
fi

sudo -n true 2>/dev/null || sudo -v
printf '%s\n' "$desired" | sudo tee /etc/pam.d/sudo_local >/dev/null
sudo chown root:wheel /etc/pam.d/sudo_local
sudo chmod 644 /etc/pam.d/sudo_local
echo "setup-pam-u2f-sudo: wrote /etc/pam.d/sudo_local (pam_u2f as sufficient)."
