// Cursor keybindings — same panel/editor ping-pong as the VSCode profile.
// Claude Code isn't installed in Cursor, so the cmd+k cmd+t binding is omitted.
[
    { "key": "cmd+j", "command": "-workbench.action.togglePanel" },
    { "key": "cmd+j", "command": "workbench.action.focusPanel",            "when": "!panelFocus" },
    { "key": "cmd+j", "command": "workbench.action.focusActiveEditorGroup", "when": "panelFocus" },

    { "key": "cmd+shift+j", "command": "workbench.action.togglePanel" },

    { "key": "cmd+\\",      "command": "workbench.action.splitEditor" },
    { "key": "cmd+k cmd+c", "command": "workbench.action.focusFirstEditorGroup" }
]
