#!/bin/bash
# Install Cursor extensions needed for Catppuccin Mocha.
# Re-runs whenever the extension list below changes (chezmoi hashes this file).
# Requires the `cursor` CLI on PATH — install via Cursor → Cmd+Shift+P
# → "Shell Command: Install 'cursor' command in PATH".

set -euo pipefail

if ! command -v cursor &>/dev/null; then
  echo "cursor CLI not found on PATH; skipping extension install." >&2
  exit 0
fi

extensions=(
  Catppuccin.catppuccin-vsc                       # Catppuccin color theme
  Catppuccin.catppuccin-vsc-icons                 # Matching file icon theme
  1Password.op-vscode                             # 1Password secret references
  eamodio.gitlens                                 # Blame, history, line annotations
  github.vscode-pull-request-github               # Review PRs in the editor
  usernamehw.errorlens                            # Inline diagnostics
  EditorConfig.EditorConfig                       # Respect .editorconfig
  streetsidesoftware.code-spell-checker           # Typo catcher
)

for ext in "${extensions[@]}"; do
  cursor --install-extension "$ext" --force
done
