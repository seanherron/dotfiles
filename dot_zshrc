# Interactive shell config

# --- History ---
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_FIND_NO_DUPS

# --- Completion ---
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
# fzf-tab takes over the completion menu, so disable zsh's built-in one.
# (fzf-tab's docs are explicit: don't enable `menu select` when using fzf-tab.)
zstyle ':completion:*' menu no
# Preview directory contents on `cd <TAB>`.
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath 2>/dev/null || ls -1 $realpath'
# Preview env-var values on `export <TAB>` / `unset <TAB>` / `$<TAB>`.
zstyle ':fzf-tab:complete:(-command-|-parameter-|-brace-parameter-|export|unset|expand):*' fzf-preview 'echo ${(P)word}'
# Switch completion groups in the fzf-tab popup with `<` / `>`.
zstyle ':fzf-tab:*' switch-group '<' '>'

# --- Options ---
setopt AUTO_CD CORRECT NO_BEEP

# --- fzf shell integration ---
if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
  # Nord colors
  export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-}\
 --color=bg+:#3B4252,bg:#2E3440,spinner:#81A1C1,hl:#616E88\
 --color=fg:#D8DEE9,header:#616E88,info:#81A1C1,pointer:#88C0D0\
 --color=marker:#88C0D0,fg+:#ECEFF4,prompt:#81A1C1,hl+:#81A1C1\
 --color=selected-bg:#434C5E\
 --color=border:#4C566A,label:#D8DEE9"
fi

# --- Plugins (Antidote) ---
if command -v brew &>/dev/null; then
  antidote_home="${ANTIDOTE_HOME:-$(brew --prefix)/opt/antidote}"
  if [[ -r "${antidote_home}/share/antidote/antidote.zsh" ]]; then
    source "${antidote_home}/share/antidote/antidote.zsh"
    antidote load "${ZDOTDIR:-$HOME}/.zsh_plugins.txt"
  fi
fi

# --- Prompt (Starship) ---
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# --- Version manager (mise) ---
# Activates mise-managed tool versions (Node, Python, Ruby, Go, etc.) per
# directory based on `.tool-versions` / `.mise.toml`. Must run before any tool
# that resolves an interpreter via PATH.
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

# --- Navigation ---
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# --- Aliases ---
if command -v eza &>/dev/null; then
  alias ls='eza --group-directories-first'
  alias ll='eza -la --group-directories-first'
  alias lt='eza --tree --level=2'
fi

if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
fi

if command -v rg &>/dev/null; then
  alias grep='rg'
fi

if command -v lazygit &>/dev/null; then
  alias lg='lazygit'
fi

# --- Shell history (atuin) ---
# Ctrl+R opens atuin's fuzzy history search. `--disable-up-arrow` keeps the
# vanilla zsh up-arrow behavior (recall the previous command verbatim).
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh --disable-up-arrow)"
fi

# --- Per-directory env (direnv) ---
# Loads `.envrc` on `cd`. Hook last so it wraps any precmd_functions set
# above (mise, starship). New `.envrc` files require `direnv allow` first.
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# --- 1Password SSH agent ---
# Point SSH/git at the 1Password agent socket.
_op_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
[[ -S "$_op_sock" ]] && export SSH_AUTH_SOCK="$_op_sock"
unset _op_sock

# Quick sanity check: which key am I about to sign with?
alias gsign='git config --get user.signingkey && echo "--- keys visible to agent ---" && ssh-add -L 2>/dev/null | head -5'

# --- Ghostty terminal support over SSH ---
# Auto-installs xterm-ghostty terminfo on remote servers so Ghostty's full
# capabilities work there. Falls back to xterm-256color only when tic is
# unavailable on the remote. Skips the check for non-interactive sessions
# (port forwarding, -N, -f, -T, or an explicit remote command).
ssh() {
    if [[ "$TERM" == "xterm-ghostty" ]] && command -v infocmp &>/dev/null; then
        # Parse args: find the hostname position and detect non-interactive flags.
        local _host_pos=0 _skip_next=0 _non_interactive=0 _i=1
        for arg in "$@"; do
            if (( _skip_next )); then _skip_next=0; (( _i++ )); continue; fi
            case "$arg" in
                # Flags that mean no interactive PTY/session
                -[NfT])                       _non_interactive=1; break ;;
                # Options that consume the next argument (not the hostname)
                -[bcDeEFIiJLlmOopQRSWw])      _skip_next=1 ;;
                # Other flags (no value)
                -*)                           ;;
                # First non-option arg is the destination
                *)                            _host_pos=$_i; break ;;
            esac
            (( _i++ ))
        done

        # Only run the terminfo check when this looks like an interactive session:
        # hostname must be present and must be the last argument (no remote command).
        if (( ! _non_interactive && _host_pos > 0 && _host_pos == $# )); then
            if ! command ssh "$@" 'test -e ~/.terminfo/x/xterm-ghostty' 2>/dev/null; then
                # Not present — try to install it.
                if ! infocmp -x xterm-ghostty 2>/dev/null | \
                        command ssh "$@" 'mkdir -p ~/.terminfo && tic -x /dev/stdin 2>/dev/null' \
                        2>/dev/null; then
                    # tic unavailable on remote; fall back to a safe terminal type.
                    TERM=xterm-256color command ssh "$@"
                    return
                fi
            fi
        fi
    fi
    command ssh "$@"
}
