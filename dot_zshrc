# Interactive shell config

# --- History ---
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_FIND_NO_DUPS

# --- Completion ---
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
# fzf-tab takes over the completion menu, so disable zsh's built-in one.
# (fzf-tab's docs are explicit: don't enable `menu select` when using fzf-tab.)
zstyle ':completion:*' menu no
# Preview directory contents on `cd <TAB>`.
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza --icons -1 --color=always $realpath 2>/dev/null || ls -1 $realpath'
# Preview env-var values on `export <TAB>` / `unset <TAB>` / `$<TAB>`.
zstyle ':fzf-tab:complete:(-command-|-parameter-|-brace-parameter-|export|unset|expand):*' fzf-preview 'echo ${(P)word}'
# Switch completion groups in the fzf-tab popup with `<` / `>`.
zstyle ':fzf-tab:*' switch-group '<' '>'

# --- Options ---
setopt AUTO_CD CORRECT NO_BEEP

# --- Plugins (Antidote) ---
if command -v brew &>/dev/null; then
  antidote_home="${ANTIDOTE_HOME:-$(brew --prefix)/opt/antidote}"
  if [[ -r "${antidote_home}/share/antidote/antidote.zsh" ]]; then
    source "${antidote_home}/share/antidote/antidote.zsh"
    antidote load "${ZDOTDIR:-$HOME}/.zsh_plugins.txt"

    # Catppuccin Mocha theme for zsh-syntax-highlighting — the plugin is
    # cloned (kind:clone) so antidote doesn't auto-source the theme file;
    # ask antidote for its path and source it after zsh-syntax-highlighting.
    if (( $+functions[antidote] )); then
      _cpc_theme="$(antidote path catppuccin/zsh-syntax-highlighting 2>/dev/null)/themes/catppuccin_mocha-zsh-syntax-highlighting.zsh"
      [[ -r "$_cpc_theme" ]] && source "$_cpc_theme"
      unset _cpc_theme
    fi
  fi
fi

# --- Prompt (Starship) ---
if command -v starship &>/dev/null; then
  eval "$(starship init zsh)"
fi

# --- Version manager (mise) ---
# Activates mise-managed tool versions (Node, Python, Ruby, Go, etc.) per
# directory based on `.tool-versions` / `.mise.toml`. Must run before any tool
# that resolves an interpreter via PATH.
if command -v mise &>/dev/null; then
  eval "$(mise activate zsh)"
fi

# --- Navigation ---
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

if command -v fzf &>/dev/null; then
  source <(fzf --zsh)
  # Catppuccin Mocha colors — https://github.com/catppuccin/fzf
  export FZF_DEFAULT_OPTS="${FZF_DEFAULT_OPTS:-}\
 --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8\
 --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc\
 --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8\
 --color=selected-bg:#45475a\
 --color=border:#313244,label:#cdd6f4"
fi

# --- Aliases ---
if command -v eza &>/dev/null; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza --icons -la --group-directories-first'
  alias lt='eza --icons --tree --level=2'
fi

if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
fi

if command -v rg &>/dev/null; then
  alias grep='rg'
fi

if command -v lazygit &>/dev/null; then
  alias lg='lazygit'
fi

# --- Shell history (atuin) ---
# Ctrl+R opens atuin's fuzzy history search. `--disable-up-arrow` keeps the
# vanilla zsh up-arrow behavior (recall the previous command verbatim).
if command -v atuin &>/dev/null; then
  eval "$(atuin init zsh --disable-up-arrow)"
fi

# --- Per-directory env (direnv) ---
# Loads `.envrc` on `cd`. Hook last so it wraps any precmd_functions set
# above (mise, starship). New `.envrc` files require `direnv allow` first.
if command -v direnv &>/dev/null; then
  eval "$(direnv hook zsh)"
fi

# --- 1Password SSH agent ---
# Point SSH/git at the 1Password agent socket when it's running locally. On a
# remote machine reached over `ssh -A`, SSH_AUTH_SOCK is set by the inbound
# connection — don't clobber it.
if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
  _op_sock="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  [[ -S "$_op_sock" ]] && export SSH_AUTH_SOCK="$_op_sock"
  unset _op_sock
fi

# Quick sanity check: which key am I about to sign with?
alias gsign='git config --get user.signingkey && echo "--- keys visible to agent ---" && ssh-add -L 2>/dev/null | head -5'
