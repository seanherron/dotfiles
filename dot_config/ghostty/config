# Ghostty configuration
# Docs: https://ghostty.org/docs/config

# Berkeley Mono first; JetBrainsMono Nerd Font catches Nerd Font icon glyphs
# and is the fallback on machines where Berkeley Mono hasn't been pulled
# from 1Password yet (see run_onchange_install-berkeley-mono.sh.tmpl).
font-family = "Berkeley Mono"
font-family = "JetBrainsMono Nerd Font"
font-size = 14

# Catppuccin Mocha everywhere — same theme in both light and dark mode
theme = "Catppuccin Mocha"

# Sensible defaults
cursor-style = block
cursor-style-blink = false
copy-on-select = clipboard
window-padding-x = 8
window-padding-y = 8
macos-option-as-alt = true
